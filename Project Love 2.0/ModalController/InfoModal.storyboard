<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.Storyboard.XIB" version="3.0" toolsVersion="24506" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <device id="retina6_3" orientation="portrait" appearance="dark"/>
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="24504"/>
        <capability name="Named colors" minToolsVersion="9.0"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="System colors in document resources" minToolsVersion="11.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <scenes>
        <scene sceneID="infoModal-scene">
            <objects>
                <viewController storyboardIdentifier="InfoModalViewController" id="infoModal-vc" customClass="InfoModalViewController" customModule="Project_Love_2_0" customModuleProvider="target" sceneMemberID="viewController">
                    <view key="view" clearsContextBeforeDrawing="NO" contentMode="scaleToFill" id="rootView">
                        <rect key="frame" x="0.0" y="0.0" width="402" height="874"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <subviews>
                            <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="modalContainer">
                                <rect key="frame" x="0.0" y="484" width="402" height="390"/>
                                <subviews>
                                    <!-- Close button -->
                                    <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="closeBtn">
                                        <rect key="frame" x="16" y="16" width="44" height="44"/>
                                        <constraints>
                                            <constraint firstAttribute="height" constant="44" id="cb-h"/>
                                            <constraint firstAttribute="width" constant="44" id="cb-w"/>
                                        </constraints>
                                        <state key="normal" title="Button"/>
                                        <buttonConfiguration key="configuration" style="filled" image="xmark" catalog="system"/>
                                        <connections>
                                            <action selector="closeButtonTapped:" destination="infoModal-vc" eventType="touchUpInside" id="close-action"/>
                                        </connections>
                                    </button>
                                    <!-- Title Label -->
                                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Title" textAlignment="center" lineBreakMode="tailTruncation" numberOfLines="1" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="titleLbl">
                                        <rect key="frame" x="70" y="26" width="262" height="24"/>
                                        <fontDescription key="fontDescription" type="boldSystem" pointSize="17"/>
                                        <nil key="textColor"/>
                                        <nil key="highlightedColor"/>
                                    </label>
                                    <!-- Main Image -->
                                    <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="mainImg">
                                        <rect key="frame" x="136" y="42" width="130" height="130"/>
                                        <constraints>
                                            <constraint firstAttribute="width" constant="130" id="img-w"/>
                                            <constraint firstAttribute="height" constant="130" id="img-h"/>
                                        </constraints>
                                    </imageView>
                                    <!-- Separator -->
                                    <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="separator">
                                        <rect key="frame" x="0.0" y="67" width="402" height="1"/>
                                        <color key="backgroundColor" systemColor="separatorColor"/>
                                        <constraints>
                                            <constraint firstAttribute="height" constant="1" id="sep-h"/>
                                        </constraints>
                                    </view>
                                    <!-- Description Label -->
                                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Description" textAlignment="center" lineBreakMode="tailTruncation" numberOfLines="0" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="descLbl">
                                        <rect key="frame" x="20" y="162" width="362" height="17"/>
                                        <fontDescription key="fontDescription" type="system" pointSize="14"/>
                                        <nil key="textColor"/>
                                        <nil key="highlightedColor"/>
                                    </label>
                                    <!-- Location Label (centered, visually distinct, shifted further down) -->
                                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Location" textAlignment="center" lineBreakMode="tailTruncation" numberOfLines="0" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="locLbl">
                                        <rect key="frame" x="20" y="210" width="362" height="17"/>
                                        <fontDescription key="fontDescription" type="system" weight="medium" pointSize="13"/>
                                        <color key="textColor" red="0.45" green="0.45" blue="0.50" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                        <nil key="highlightedColor"/>
                                    </label>
                                    <!-- Let's Do This Button (pinned to bottom) -->
                                    <button contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="actionBtn">
                                        <rect key="frame" x="25" y="310" width="352" height="35"/>
                                        <state key="normal" title="Button"/>
                                        <buttonConfiguration key="configuration" style="filled" title="Let's do this">
                                            <color key="baseForegroundColor" white="0.0" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                            <color key="baseBackgroundColor" name="AppBackground"/>
                                        </buttonConfiguration>
                                        <connections>
                                            <action selector="letsDoThisButtonTapped:" destination="infoModal-vc" eventType="touchUpInside" id="action-btn-action"/>
                                        </connections>
                                    </button>
                                </subviews>
                                <color key="backgroundColor" name="AppBackground"/>
                                <constraints>
                                    <!-- Close button positioning -->
                                    <constraint firstItem="closeBtn" firstAttribute="top" secondItem="modalContainer" secondAttribute="top" constant="16" id="c1"/>
                                    <constraint firstItem="closeBtn" firstAttribute="leading" secondItem="modalContainer" secondAttribute="leading" constant="16" id="c2"/>
                                    <!-- Title label centered with close button -->
                                    <constraint firstItem="titleLbl" firstAttribute="centerY" secondItem="closeBtn" secondAttribute="centerY" id="ct1"/>
                                    <constraint firstItem="titleLbl" firstAttribute="leading" secondItem="closeBtn" secondAttribute="trailing" constant="10" id="ct2"/>
                                    <constraint firstAttribute="trailing" secondItem="titleLbl" secondAttribute="trailing" constant="70" id="ct3"/>
                                    <!-- Separator -->
                                    <constraint firstItem="separator" firstAttribute="leading" secondItem="modalContainer" secondAttribute="leading" id="c3"/>
                                    <constraint firstAttribute="trailing" secondItem="separator" secondAttribute="trailing" id="c4"/>
                                    <constraint firstItem="separator" firstAttribute="top" secondItem="closeBtn" secondAttribute="bottom" constant="7" id="c5"/>
                                    <!-- Image centered -->
                                    <constraint firstItem="mainImg" firstAttribute="centerX" secondItem="modalContainer" secondAttribute="centerX" id="c6"/>
                                    <constraint firstItem="mainImg" firstAttribute="top" secondItem="closeBtn" secondAttribute="bottom" constant="-18" id="c7"/>
                                    <!-- Description below image -->
                                    <constraint firstItem="descLbl" firstAttribute="top" secondItem="mainImg" secondAttribute="bottom" constant="-10" id="c8"/>
                                    <constraint firstItem="descLbl" firstAttribute="leading" secondItem="modalContainer" secondAttribute="leading" constant="20" id="c9"/>
                                    <constraint firstAttribute="trailing" secondItem="descLbl" secondAttribute="trailing" constant="20" id="c10"/>
                                    <!-- Location label well below description (28pt gap) -->
                                    <constraint firstItem="locLbl" firstAttribute="top" secondItem="descLbl" secondAttribute="bottom" constant="28" id="c11"/>
                                    <constraint firstItem="locLbl" firstAttribute="leading" secondItem="modalContainer" secondAttribute="leading" constant="20" id="c12"/>
                                    <constraint firstAttribute="trailing" secondItem="locLbl" secondAttribute="trailing" constant="20" id="c13b"/>
                                    <!-- Action button pinned to bottom -->
                                    <constraint firstAttribute="bottom" secondItem="actionBtn" secondAttribute="bottom" constant="40" id="c15"/>
                                    <constraint firstItem="actionBtn" firstAttribute="leading" secondItem="modalContainer" secondAttribute="leading" constant="25" id="c16"/>
                                    <constraint firstAttribute="trailing" secondItem="actionBtn" secondAttribute="trailing" constant="25" id="c17"/>
                                    <!-- Modal height -->
                                    <constraint firstAttribute="height" constant="390" id="c18"/>
                                </constraints>
                            </view>
                        </subviews>
                        <viewLayoutGuide key="safeArea" id="safeArea"/>
                        <color key="backgroundColor" white="0.0" alpha="0.0" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                        <constraints>
                            <constraint firstItem="modalContainer" firstAttribute="trailing" secondItem="safeArea" secondAttribute="trailing" id="mc1"/>
                            <constraint firstItem="modalContainer" firstAttribute="leading" secondItem="safeArea" secondAttribute="leading" id="mc2"/>
                            <constraint firstAttribute="bottom" secondItem="modalContainer" secondAttribute="bottom" id="mc3"/>
                        </constraints>
                    </view>
                    <connections>
                        <outlet property="closeButton" destination="closeBtn" id="close-conn"/>
                        <outlet property="descriptionLabel" destination="descLbl" id="desc-conn"/>
                        <outlet property="letsDoThisButton" destination="actionBtn" id="action-conn"/>
                        <outlet property="locationLabel" destination="locLbl" id="loclbl-conn"/>
                        <outlet property="mainImage" destination="mainImg" id="img-conn"/>
                        <outlet property="modalView" destination="modalContainer" id="modal-conn"/>
                        <outlet property="titleLabel" destination="titleLbl" id="title-conn"/>
                    </connections>
                </viewController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="138" y="153"/>
        </scene>
    </scenes>
    <resources>
        <image name="xmark" catalog="system" width="128" height="113"/>
        <namedColor name="AppBackground">
            <color red="0.94900000095367432" green="0.94900000095367432" blue="0.96899998188018799" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
        </namedColor>
        <systemColor name="separatorColor">
            <color red="0.23529411759999999" green="0.23529411759999999" blue="0.26274509800000001" alpha="0.28999999999999998" colorSpace="custom" customColorSpace="sRGB"/>
        </systemColor>
    </resources>
</document>
